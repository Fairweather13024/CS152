# Misplaced tiles heuristic
@memoized_cost
def h1(state):
    """

    This function returns the number of misplaced tiles, given the board state
    Input:
        -state: the board state as a list of lists
    Output:
        -h: the number of misplaced tiles
    """
    node_for_goal_state = PuzzleNode(state)
    cost = 0
    # check whether each tile is in the correct space or else add a cost of 1
    for i in range(len(state)):
          for j in range(len(state)):
                if node_for_goal_state.goal_state[i][j] != state[i][j]:
                      cost += 1


    return cost

# Manhattan distance heuristic
@memoized_cost
def h2(state):
    """
    This function returns the Manhattan distance from the solved state, 
    given the board state

    *** This implementation cares about the index of the element in the 8-puzzle 
    relative to the goal state of that element***
    Input:
        -state: the board state as a list of lists
    Output:
        -h: the Manhattan distance from the solved configuration
    """
    distance = 0 
    
    for i in range(0,len(state)):
      for j in range(0, len(state)):
        
        value = state[i][j]-1
        x = state[i][j]%len(state)
        y = state[i][j]//len(state)

        distance += abs(x-j)+abs(y-i)
    return distance
    
