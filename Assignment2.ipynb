#Now, define the class PuzzleNode:
class PuzzleNode:
    """
    Class PuzzleNode: Provides a structure for performing A* search for the n^2-1 puzzle

    state - 2D array of the state of the puzzle at that node (note that the empty space is denoted by 0 rather than a more ideal implementation of float('inf'))
    h_value - The calculated h_value of the node that will be reassigned by the heuristic upon calculation
    parent_node = state to keep track of the node's parent in the tree problem so that we can track visited 
    nodes and also memoize them using object ids
    g_value - distance from the root to the current state. Updated directly from the parent
    f_value - calculated cost of the path

    """
    # YOUR CODE HERE
    def __init__(self,state, h_value = 0,  parent_node=None):
      self.state = state
      #checking the shape of the input
      assert (len(self.state) == 3 and len(self.state[0]) ==3 and len(self.state[1])==3 and len(self.state[2]) == 3)

      self.parent_node = parent_node
      self.h_value = h_value
      self.coords = list(itertools.product(range(len(self.state)),range(len(self.state))))
      
      self.goal_state= []
      #generate goal state
      for i in range(len(self.state)):
            self.goal_state.append([])
            for j in range(len(self.state)):
                  self.goal_state[i].append(i*len(self.state) + j + 1)
      #create the empty space in the goal state
      self.goal_state[-1][-1] = 0

      
      if self.parent_node == None:
        print("root")
        self.g_value = 0
      else:
        self.g_value = self.parent_node.g_value + 1

      self.f_value = self.g_value + self.h_value

    def __lt__(self, other):   
      return (self.f_value <= other.f_value)
    
    def __str__(self):
      """
      Uses numpy to return a matrix
      """
      
      return str(self.state)
      

    def path(self):
      """ 
      Finds the path taken to the root using reverse DFS traversal
      
      path_taken - array of all the states from the goal to the root that the algorithm took
      steps - a measure of efficiency of the algorithm to find the goal state in this tree problem
      """

      current = self.parent_node  #setting the first element of the path as the node's parent
      path_taken = [] 
    
      #storing the path as the upward traversal continues as long as we are not at the root
      while current != None:
        path_taken.append(current.state)
        current = current.parent_node
        
      return path_taken


    def swap(self, coming_from, going_to):
      """
      Swaps the 'o' with the element that it is supposed to swap with. 
      Stores the incoming state as the parent of the new state and returns the new state

      coming_from - tuple with the coordinates of the initial place of the space
      going_to - tuple with the coordinates of teh destination of the space

      new_state - This is the board as the new state after a swap
      """
      #make a placeholder state to be edited by a swap
      new_state = copy.deepcopy(self.state) # have to use the slices in order to avoid using a pointer to the original (which would edit the original)

      #collect the coordinates from the incoming tuples
      i = coming_from[0]
      j = coming_from[1]
      row = going_to[0]
      column = going_to[1]

      # swapping the initial place with the destination in place
      new_state[i][j], new_state[row][column] = new_state[row][column], new_state[i][j]
      return new_state



    def movement(self):
      """
      Applies one of 4 movements to the index of the '0' 

      moves - array that stores the moves taken
      """
      moves = []
      # get possible enumeration of coordinates from the input state
      # coords = [(0, 0), (0, 1), (0, 2), (1, 0), (1, 1), (1, 2), (2, 0), (2, 1), (2, 2)]

      for i, j in self.coords:
          directions = {'Right':(i, j+1),'Left':(i, j-1),'Up':(i-1, j),'Down':(i+1, j)}

          for direction, (row, column) in directions.items():
                #finding the space as long as it is within teh bounds
              if row >= 0 and column >= 0 and row < len(self.state) and column < len(self.state) and self.state[row][column] == 0:
                  move = self.swap((i,j), (row,column))
                  moves.append(move)
      return moves





