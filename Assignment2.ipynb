"""
workflow:
start a cache dictionary
take the heuristic function which returns a cost 
store the state as the key and the cost from the heuristic as the value

run a check for the state in the cache
return the cost 
else
calculate the cost and store it in the cache
"""

def memoized_cost( func):
    """
    workflow:
    start a cache dictionary
    take the heuristic function which returns a cost 
    store the state as the key and the cost from the heuristic as the value

    run a check for the state in the cache
    return the cost 
    else
    calculate the cost and store it in the cache
    """
    cache = {}
    def wrapper(*args):
      key = str(args[0])
      if key not in cache:
        cache[key] = func(args[0])
      return cache[key]

    return wrapper

